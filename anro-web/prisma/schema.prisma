generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model PageContent {
  id        String   @id @default(cuid())
  pageKey   String   @unique
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([pageKey])
}

model MediaAsset {
  id         String   @id
  pageKey    String
  sectionKey String
  publicId   String
  url        String
  secureUrl  String
  format     String?
  width      Int?
  height     Int?
  bytes      Int?
  createdAt  DateTime @default(now())
  updatedAt  DateTime

  @@index([pageKey, sectionKey])
  @@index([publicId])
}
