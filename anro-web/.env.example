# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/anro

# Secret para firmar JWT de sesión admin
JWT_SECRET=replace-with-a-long-random-secret

# Opcional: si no se define, el frontend usa /api (Next.js Route Handlers)
NEXT_PUBLIC_API_URL=/api

# Brevo (formulario de contacto)
BREVO_API_KEY=
CONTACT_TO_EMAIL=
CONTACT_FROM_EMAIL=
CONTACT_FROM_NAME=ANRO Web
